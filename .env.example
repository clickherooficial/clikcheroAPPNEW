# ClickHero — variaveis de ambiente
# Copie este arquivo para `.env` e preencha. `.env` e gitignored.

# Client-side (Vite injeta no bundle — nunca coloque segredos reais aqui)
VITE_SUPABASE_PROJECT_ID="ckxewdahdiambbxmqxgb"
VITE_SUPABASE_URL="https://ckxewdahdiambbxmqxgb.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="<anon_key_publica>"

# CLI only — NUNCA commite. Pega em https://supabase.com/dashboard/account/tokens
# SUPABASE_ACCESS_TOKEN="sbp_..."

# Feature flag — Fase 2 (business-archetype-personas)
# Default: ON (ausente = ON). Setar literal "false" para desativar globalmente
# toda a logica de personas (ai-chat volta ao SYSTEM_PROMPT base, archetype-detector
# vira no-op, propose_campaign ignora archetype). Usar pra rollback rapido.
ENABLE_ARCHETYPE_PERSONAS=true
